# Copy this to infra/.env and fill in secrets before deploying.
# Never commit the real .env file.

# PostgreSQL
POSTGRES_USER=threew
POSTGRES_PASSWORD=change_me
POSTGRES_DB=threew

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=threew
MINIO_ROOT_PASSWORD=change_me_minio

# App secrets
JWT_SECRET=change_me_jwt_secret_min_32_chars

# Anthropic (optional — Ollama is used as fallback if unset)
ANTHROPIC_API_KEY=

# EC2 public hostname or IP (used for CORS allowlist)
EC2_HOST=your-ec2-ip-or-domain.com
