# Use the postgresql+psycopg:// scheme, not plain postgresql:// — this
# project depends on psycopg (v3), and SQLAlchemy defaults to the psycopg2
# driver unless the scheme says otherwise.
POSTGRES_DSN=postgresql+psycopg://threew:changeme@localhost:5432/threew

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=threew
MINIO_SECRET_KEY=changeme_min_8_chars

JWT_SECRET=change_this_to_a_long_random_string

DUCKDB_PATH=./data/analytics.duckdb
PARQUET_DIR=./data/parquet
