# Use the postgresql+psycopg:// scheme, not plain postgresql:// — this
# project depends on psycopg (v3), and SQLAlchemy defaults to the psycopg2
# driver unless the scheme says otherwise.
POSTGRES_DSN=postgresql+psycopg://threew:changeme@localhost:5432/threew

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=threew
MINIO_SECRET_KEY=changeme_min_8_chars

JWT_SECRET=change_this_to_a_long_random_string

DUCKDB_PATH=./data/analytics.duckdb
PARQUET_DIR=./data/parquet
RAW_DATA_DIR=./data/raw

# Used to list published WMS layers for the map's GeoServer layer
# toggles. Map still works fine if this is unreachable — the layer
# list just comes back empty.
GEOSERVER_URL=http://localhost:8600/geoserver

# Defaults to the local Vite dev-server port range (5173-5190) — override
# with a JSON array of your real frontend origin(s) in any non-local
# deployment, e.g. CORS_ORIGINS=["https://ops.example.com"]
CORS_ORIGINS=

# Claude — required for the AI agent. Set to your Anthropic API key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS S3 — set USE_REAL_S3=true to read raw files from S3 and write
# processed Parquet back to S3 instead of local disk. On EC2 with an
# IAM role attached, leave AWS_ACCESS_KEY/SECRET blank and boto3 will
# use the instance metadata automatically.
USE_REAL_S3=false
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# S3 bucket and prefix layout (matches jejak-mappro-demo structure).
S3_BUCKET=jejak-mappro-demo
S3_CELL_REF_PREFIX=3W-data/site-coverage-params/referenceData/
S3_LOCATION_DATA_PREFIX=3W-data/site-coverage-params/locationData/
S3_NETWORK_DATA_PREFIX=3W-data/raw-network-data/
S3_TRAIN_EXCEL_PREFIX=3W-data/train-ai-data/excel-data/
S3_TRAIN_PDF_PREFIX=3W-data/train-ai-data/pdf-data/
S3_PROCESSED_PREFIX=3W-data/processed/
