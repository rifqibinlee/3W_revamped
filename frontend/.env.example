# Backend API base URL. Defaults to http://localhost:8000 if unset.
VITE_API_BASE_URL=http://localhost:8000

# GeoServer WMS endpoint, queried directly from the browser for the
# Map page's GeoServer layer toggles. Defaults to the infra/docker-compose.yml
# port mapping if unset.
VITE_GEOSERVER_URL=http://localhost:8600/geoserver
